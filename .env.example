# Copy to .env and fill in. (.env is gitignored — keep your secrets out of version control.)
# These are just initial defaults — everything here can also be set/edited
# later from the web UI's Configuration card, which persists to the /data volume.

BAMBUDDY_URL=https://your-bambuddy.example.com
BAMBUDDY_API_KEY=your-bambuddy-api-key

MANYFOLD_URL=https://your-manyfold.example.com
MANYFOLD_CLIENT_ID=your-manyfold-oauth-client-id
MANYFOLD_CLIENT_SECRET=your-manyfold-oauth-client-secret

# Optional:
# MANYFOLD_TOKEN=                 # fallback token (read-only; can't upload)
# MANYFOLD_LIBRARY_ID=1
# MANYFOLD_SYNC_DEBUG=0
